{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "ninja.vdo.streamdeck",
  "Name": "VDO.Ninja",
  "Author": "VDO.Ninja",
  "URL": "https://vdo.ninja",
  "Description": "Control VDO.Ninja from Stream Deck keys and dials: mic, camera, guests, scenes, mixer layouts, PTZ, volume, and custom API commands on any VDO.Ninja page opened with &api=KEY.",
  "Version": "0.1.1.0",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.8"
  },
  "Nodejs": {
    "Version": "20"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    },
    {
      "Platform": "mac",
      "MinimumVersion": "12"
    }
  ],
  "Category": "VDO.Ninja",
  "CategoryIcon": "imgs/actions/category",
  "Icon": "imgs/plugin",
  "CodePath": "bin/plugin.js",
  "PropertyInspectorPath": "ui/action-settings.html",
  "Actions": [
    {
      "UUID": "ninja.vdo.streamdeck.connection",
      "Name": "Connection Status",
      "Tooltip": "Configure the VDO.Ninja API key and show connection status.",
      "Icon": "imgs/actions/connection",
      "Controllers": [
        "Keypad"
      ],
      "DisableAutomaticStates": true,
      "States": [
        {
          "Name": "Waiting",
          "Image": "imgs/state-neutral",
          "Title": "VDO",
          "ShowTitle": true
        },
        {
          "Name": "Connected",
          "Image": "imgs/state-on",
          "Title": "VDO",
          "ShowTitle": true
        }
      ],
      "UserTitleEnabled": false
    },
    {
      "UUID": "ninja.vdo.streamdeck.local-control",
      "Name": "Local Control",
      "Tooltip": "Control the local VDO.Ninja page: mic, camera, speaker, record, hand, screen share, and more.",
      "Icon": "imgs/actions/local",
      "Controllers": [
        "Keypad"
      ],
      "DisableAutomaticStates": true,
      "States": [
        {
          "Name": "Inactive",
          "Image": "imgs/state-off",
          "Title": "Local",
          "ShowTitle": true
        },
        {
          "Name": "Active",
          "Image": "imgs/state-on",
          "Title": "Local",
          "ShowTitle": true
        }
      ],
      "UserTitleEnabled": false
    },
    {
      "UUID": "ninja.vdo.streamdeck.select-guest",
      "Name": "Select Guest",
      "Tooltip": "Select a VDO.Ninja guest by slot, stream ID, next/previous guest, or first held guest for other actions to follow.",
      "Icon": "imgs/actions/select",
      "Controllers": [
        "Keypad"
      ],
      "DisableAutomaticStates": true,
      "States": [
        {
          "Name": "No Target",
          "Image": "imgs/state-off",
          "Title": "Select",
          "ShowTitle": true
        },
        {
          "Name": "Target Selected",
          "Image": "imgs/state-on",
          "Title": "Target",
          "ShowTitle": true
        }
      ],
      "UserTitleEnabled": false
    },
    {
      "UUID": "ninja.vdo.streamdeck.guest-command",
      "Name": "Guest Command",
      "Tooltip": "Control a VDO.Ninja guest by slot, stream ID, selected guest, or first held guest.",
      "Icon": "imgs/actions/guest",
      "Controllers": [
        "Keypad"
      ],
      "DisableAutomaticStates": true,
      "States": [
        {
          "Name": "Inactive",
          "Image": "imgs/state-off",
          "Title": "Guest",
          "ShowTitle": true
        },
        {
          "Name": "Active",
          "Image": "imgs/state-on",
          "Title": "Guest",
          "ShowTitle": true
        }
      ],
      "UserTitleEnabled": false
    },
    {
      "UUID": "ninja.vdo.streamdeck.guest-scene",
      "Name": "Guest Scene",
      "Tooltip": "Toggle a VDO.Ninja guest in an arbitrary scene by slot, stream ID, selected guest, or first held guest.",
      "Icon": "imgs/actions/scene",
      "Controllers": [
        "Keypad"
      ],
      "DisableAutomaticStates": true,
      "States": [
        {
          "Name": "Not In Scene",
          "Image": "imgs/state-off",
          "Title": "Scene",
          "ShowTitle": true
        },
        {
          "Name": "In Scene",
          "Image": "imgs/state-on",
          "Title": "Scene",
          "ShowTitle": true
        }
      ],
      "UserTitleEnabled": false
    },
    {
      "UUID": "ninja.vdo.streamdeck.mixer-control",
      "Name": "Mixer Control",
      "Tooltip": "Control VDO.Ninja mixer layouts, guest slots, all-guest mute, and all-guest transfer.",
      "Icon": "imgs/actions/mixer",
      "Controllers": [
        "Keypad"
      ],
      "DisableAutomaticStates": true,
      "States": [
        {
          "Name": "Inactive",
          "Image": "imgs/mixer-off",
          "Title": "Mixer",
          "ShowTitle": true
        },
        {
          "Name": "Active",
          "Image": "imgs/mixer-on",
          "Title": "Mixer",
          "ShowTitle": true
        }
      ],
      "UserTitleEnabled": false
    },
    {
      "UUID": "ninja.vdo.streamdeck.ptz-key",
      "Name": "PTZ Key",
      "Tooltip": "Send local or guest PTZ camera commands: zoom, pan, tilt, focus, exposure, and guest autofocus.",
      "Icon": "imgs/actions/ptz",
      "Controllers": [
        "Keypad"
      ],
      "DisableAutomaticStates": true,
      "States": [
        {
          "Name": "Unavailable",
          "Image": "imgs/state-off",
          "Title": "PTZ",
          "ShowTitle": true
        },
        {
          "Name": "Ready",
          "Image": "imgs/state-on",
          "Title": "PTZ",
          "ShowTitle": true
        }
      ],
      "UserTitleEnabled": false
    },
    {
      "UUID": "ninja.vdo.streamdeck.ptz-dial",
      "Name": "PTZ Dial",
      "Tooltip": "Adjust local or guest PTZ camera controls with Stream Deck + dials.",
      "Icon": "imgs/actions/ptz",
      "Controllers": [
        "Encoder"
      ],
      "Encoder": {
        "Icon": "imgs/ptz",
        "StackColor": "#38bdf8",
        "layout": "$X1",
        "TriggerDescription": {
          "Rotate": "Adjust PTZ",
          "Push": "Configured PTZ push action",
          "Touch": "Configured PTZ push action"
        }
      },
      "States": [
        {
          "Name": "Ready",
          "Image": "imgs/ptz",
          "Title": "PTZ",
          "ShowTitle": true
        }
      ],
      "UserTitleEnabled": false
    },
    {
      "UUID": "ninja.vdo.streamdeck.value-dial",
      "Name": "Value Dial",
      "Tooltip": "Adjust VDO.Ninja values with Stream Deck + dials: volume, panning, bitrate, buffer delay, and guest volume.",
      "Icon": "imgs/actions/value",
      "Controllers": [
        "Encoder"
      ],
      "Encoder": {
        "Icon": "imgs/value",
        "StackColor": "#22c55e",
        "layout": "$X1",
        "TriggerDescription": {
          "Rotate": "Adjust value",
          "Push": "Reset or cycle value control",
          "Touch": "Reset or cycle value control"
        }
      },
      "States": [
        {
          "Name": "Ready",
          "Image": "imgs/value",
          "Title": "Value",
          "ShowTitle": true
        }
      ],
      "UserTitleEnabled": false
    },
    {
      "UUID": "ninja.vdo.streamdeck.custom-command",
      "Name": "Custom Command",
      "Tooltip": "Send any VDO.Ninja API command with action, target, value, and value2.",
      "Icon": "imgs/actions/custom",
      "Controllers": [
        "Keypad"
      ],
      "DisableAutomaticStates": true,
      "States": [
        {
          "Name": "Ready",
          "Image": "imgs/state-neutral",
          "Title": "Command",
          "ShowTitle": true
        }
      ],
      "UserTitleEnabled": false
    }
  ]
}
