{
  "name": "vdo-ninja-streamdeck-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Native Elgato Stream Deck plugin for controlling VDO.Ninja via &api.",
  "type": "module",
  "scripts": {
    "assets": "node scripts/generate-png-assets.mjs",
    "build": "npm run assets && tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0",
    "qrcode-generator": "^2.0.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.5.1"
  }
}
